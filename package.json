{
    "name": "kdbxweb",
    "version": "2.2.0",
    "description": "Kdbx KeePass database reader for web",
    "type": "commonjs",
    "main": "dist/pkg/index.cjs",
    "module": "dist/pkg/index.mjs",
    "private": false,
    "types": "dist/pkg/index.d.ts",
    "sideEffects": false,
    "unpkg": "dist/kdbxweb.js",
    "jsdelivr": "dist/kdbxweb.js",
    "engines": {
        "node": "^18.18.0"
    },
    "license": "MIT",
    "readme": "README.md",
    "funding": {
        "type": "github",
        "url": "https://github.com/sponsors/antelle"
    },
    "exports": {
        ".": {
            "types": "./dist/pkg/index.d.ts",
            "import": "./dist/pkg/index.mjs",
            "require": "./dist/pkg/index.cjs",
            "default": "./dist/pkg/index.mjs"
        },
        "./dist/kdbxweb.js": "./dist/kdbxweb.js",
        "./dist/kdbxweb.min.js": "./dist/kdbxweb.min.js",
        "./package.json": "./package.json"
    },
    "scripts": {
        "test": "npm run tests:node",
        "start": "npm run lint && npm run build",
        "tsc": "tsc",
        "typecheck": "tsc -p conf/tsconfig.types.json",
        "lint": "eslint lib test conf scripts",
        "build": "npm run clean && npm run typecheck && npm run tests:cover && npm run build:modules && npm run pack:tests && npm run pack:dist-debug && npm run pack:dist-prod && npm run verify:artifacts && npm run verify:bundle-size && npm run compat:node",
        "clean": "rimraf dist .nyc_output coverage",
        "build:types": "tsc -p conf/tsconfig.types.json",
        "build:modules": "tsup --config tsup.config.ts && npm run build:types",
        "pack:dist-prod": "webpack --progress --mode=production --config conf/webpack.config.ts --mode production",
        "pack:dist-debug": "webpack --progress --mode=development --devtool source-map --config conf/webpack.config.ts --mode development",
        "webpack-stats": "webpack --mode=production --json --config conf/webpack.config.ts > dist/stats.json",
        "pack:tests": "webpack --progress --config conf/webpack.tests.config.ts",
        "tests:node": "mocha --require ts-node/register --recursive --reporter spec test/**/*.spec.ts",
        "tests:cover": "nyc --reporter=lcov npm run tests:node",
        "verify:artifacts": "node scripts/check-artifacts.mjs",
        "verify:bundle-size": "node scripts/check-bundle-size.mjs",
        "verify:types": "npm run pack:dist-prod && publint",
        "compat:node": "node scripts/check-node-compat.mjs",
        "compare:bundlers": "npm run clean && npm run build:modules && npm run pack:dist-debug && npm run pack:dist-prod && node scripts/compare-bundlers.mjs",
        "sbom": "cyclonedx-npm --output-file dist/sbom.json",
        "script:dump-header": "ts-node scripts/dump-header",
        "script:kdbx-size-profiler": "ts-node scripts/kdbx-size-profiler",
        "script:kdbx-to-xml": "ts-node scripts/kdbx-to-xml",
        "script:make-big-files": "ts-node scripts/make-big-files",
        "script:save-perf-test": "ts-node scripts/save-perf-test",
        "script:bench-merge": "ts-node scripts/benchmark-merge.ts"
    },
    "keywords": [
        "kdbx",
        "keepass"
    ],
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@cyclonedx/cyclonedx-npm": "^4.2.1",
        "@istanbuljs/nyc-config-typescript": "^1.0.2",
        "@nodelib/fs.walk": "^3.0.1",
        "@types/expect.js": "^0.3.32",
        "@types/mocha": "^10.0.10",
        "@types/terser-webpack-plugin": "^5.2.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "base64-loader": "^1.0.0",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-chai-friendly": "^1.2.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-mocha": "^11.2.0",
        "eslint-plugin-n": "17.24.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-standard": "^5.0.0",
        "expect.js": "^0.3.1",
        "exports-loader": "^5.0.0",
        "mocha": "^11.7.5",
        "nyc": "^18.0.0",
        "prettier": "^3.8.3",
        "prettier-eslint": "^16.4.2",
        "publint": "^0.3.18",
        "rimraf": "^6.1.3",
        "source-map-support": "^0.5.21",
        "stats-webpack-plugin": "^0.7.0",
        "terser-webpack-plugin": "^5.4.0",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.1",
        "typescript": "^6.0.2",
        "webpack": "^5.106.2",
        "webpack-cli": "^7.0.2"
    },
    "dependencies": {
        "@xmldom/xmldom": "^0.9.9",
        "fflate": "^0.8.2"
    }
}
